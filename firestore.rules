rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /inquiries/{inquiryId} {
      // Allow any user to create an inquiry form submission
      allow create: if request.resource.data.keys().hasAll(['type', 'name', 'phone', 'service', 'message', 'createdAt']) 
                    && request.resource.data.type in ['contact_form', 'plan_purchase'];
      
      // No reading inquiries from the client-side! Admin reads them from Firebase Console.
      allow read, update, delete: if false; 
    }
  }
}
